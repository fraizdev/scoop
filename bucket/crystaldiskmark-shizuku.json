{
    "version": "9.0.3",
    "description": "A simple disk benchmark software (Shizuku Edition)",
    "homepage": "https://crystalmark.info/en/software/crystaldiskmark/",
    "license": "BSD-3-Clause",
    "url": "https://sourceforge.net/projects/crystaldiskmark/files/9.0.3/CrystalDiskMark9_0_3Shizuku.zip",
    "hash": "sha1:a299405c2e19f574663f39691ea309f883dead76",
    "pre_install": [
        "$paths = @('64S', '32S')",
        "$paths | ForEach-Object {",
        "    if (!(Test-Path \"$persist_dir\\DiskMark$_.ini\")) {",
        "        New-Item -Path \"$dir\\DiskMark$_.ini\" -ItemType File | Out-Null",
        "    }",
        "}"
    ],
    "architecture": {
        "64bit": {
            "bin": [
                [
                    "DiskMark64S.exe",
                    "DiskMark(Shizuku)"
                ]
            ],
            "shortcuts": [
                [
                    "DiskMark64S.exe",
                    "CrystalDiskMark(Shizuku)"
                ]
            ]
        },
        "32bit": {
            "bin": [
                [
                    "DiskMark32S.exe",
                    "DiskMark(Shizuku)"
                ]
            ],
            "shortcuts": [
                [
                    "DiskMark32S.exe",
                    "CrystalDiskMark(Shizuku)"
                ]
            ]
        }
    },
    "persist": [
        "DiskMark32S.ini",
        "DiskMark64S.ini"
    ],
    "checkver": {
        "sourceforge": "crystaldiskmark",
        "regex": "([\\d.a-zA-Z]+)/CrystalDiskMark.*(Shizuku).zip"
    },
    "autoupdate": {
        "url": "https://sourceforge.net/projects/crystaldiskmark/files/$version/CrystalDiskMark$underscoreVersionShizuku.zip"
    }
}
