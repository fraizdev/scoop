{
    "version": "2026.4.1",
    "description": "GTK stack for Windows",
    "homepage": "https://github.com/wingtk/gvsbuild",
    "license": "GPL-2.0",
    "url": [
        "https://github.com/wingtk/gvsbuild/releases/download/2026.4.1/GTK3_Gvsbuild_2026.4.1_x64.zip",
        "https://github.com/wingtk/gvsbuild/releases/download/2026.4.1/GTK4_Gvsbuild_2026.4.1_x64.zip"
    ],
    "hash": [
        "09e819972b3bfdf5887c4357c87504c9c288fea5a5c62effbde0a8061ef34588",
        "a6c3e4b222a5a699f2f33140635033124d70f5ca21f9e9fc845d76e5337530ab"
    ],
    "post_install": [
        "$bin_path = Join-Path $dir \"bin\"",
        "$lib_path = Join-Path $dir \"lib\"",
        "$inc_path = Join-Path $dir \"include\"",
        "$inc_paths = @(",
        "    Join-Path $inc_path \"cairo\"",
        "    Join-Path $inc_path \"glib-2.0\"",
        "    Join-Path $inc_path \"gobject-introspection-1.0\"",
        "    Join-Path $lib_path \"glib-2.0\\include\"",
        ")",
        "$env_key = (Get-Item -Path 'HKCU:').OpenSubKey('Environment', $true)",
        "$env_key.SetValue(\"Path\", \"${bin_path};$($env:Path)\", \"ExpandString\")",
        "$env_key.SetValue(\"LIB\", \"${lib_path};$($env:LIB)\", \"ExpandString\")",
        "$env_key.SetValue(\"INCLUDE\", \"${inc_path};$($inc_paths -join \";\");$($env:INCLUDE)\", \"ExpandString\")"
    ],
    "checkver": {
        "github": "https://github.com/wingtk/gvsbuild"
    },
    "autoupdate": {
        "url": [
            "https://github.com/wingtk/gvsbuild/releases/download/$version/GTK3_Gvsbuild_$version_x64.zip",
            "https://github.com/wingtk/gvsbuild/releases/download/$version/GTK4_Gvsbuild_$version_x64.zip"
        ]
    }
}
