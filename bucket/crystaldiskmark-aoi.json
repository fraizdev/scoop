{
    "version": "9.0.3",
    "description": "A simple disk benchmark software (Aoi Edition)",
    "homepage": "https://crystalmark.info/en/software/crystaldiskmark/",
    "license": "BSD-3-Clause",
    "url": "https://sourceforge.net/projects/crystaldiskmark/files/9.0.3/CrystalDiskMark9_0_3Aoi.zip",
    "hash": "sha1:9b7046c73dcd5844f911597b868e7c83ae425a04",
    "pre_install": [
        "$paths = @('64A', '32A')",
        "$paths | ForEach-Object {",
        "    if (!(Test-Path \"$persist_dir\\DiskMark$_.ini\")) {",
        "        New-Item -Path \"$dir\\DiskMark$_.ini\" -ItemType File | Out-Null",
        "    }",
        "}"
    ],
    "architecture": {
        "64bit": {
            "bin": [
                [
                    "DiskMark64A.exe",
                    "DiskMark(Aoi)"
                ]
            ],
            "shortcuts": [
                [
                    "DiskMark64A.exe",
                    "CrystalDiskMark(Aoi)"
                ]
            ]
        },
        "32bit": {
            "bin": [
                [
                    "DiskMark32A.exe",
                    "DiskMark(Aoi)"
                ]
            ],
            "shortcuts": [
                [
                    "DiskMark32A.exe",
                    "CrystalDiskMark(Aoi)"
                ]
            ]
        }
    },
    "persist": [
        "DiskMark32A.ini",
        "DiskMark64A.ini"
    ],
    "checkver": {
        "sourceforge": "crystaldiskmark",
        "regex": "([\\d.a-zA-Z]+)/CrystalDiskMark.*(Aoi).zip"
    },
    "autoupdate": {
        "url": "https://sourceforge.net/projects/crystaldiskmark/files/$version/CrystalDiskMark$underscoreVersionAoi.zip"
    }
}
